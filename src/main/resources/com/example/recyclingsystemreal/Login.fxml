<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane prefHeight="600" prefWidth="900" style="-fx-background-color: #F0F4F0;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.recyclingsystemreal.LoginController">

    <!-- Left green panel -->
    <HBox>
        <VBox prefHeight="600" prefWidth="420" style="-fx-background-color: #1D6B4A; -fx-alignment: center; -fx-padding: 60;">
            <Label style="-fx-font-size: 64px; -fx-text-fill: #9FE1CB;" text="♻" />
            <Label style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: white; -fx-padding: 8 0 0 0;" text="EcoRewards" />
            <Label style="-fx-font-size: 13px; -fx-text-fill: #9FE1CB; -fx-padding: 4 0 0 0; -fx-wrap-text: true; -fx-alignment: center;" text="Campus Bottle Recycling System" />

            <VBox spacing="16" style="-fx-padding: 48 0 0 0;">
                <HBox spacing="12" style="-fx-alignment: center-left;">
                    <Label style="-fx-text-fill: #5DCAA5; -fx-font-size: 10px;" text="●" />
                    <Label style="-fx-text-fill: #C0DDC0; -fx-font-size: 13px;" text="Earn points for every bottle" />
                </HBox>
                <HBox spacing="12" style="-fx-alignment: center-left;">
                    <Label style="-fx-text-fill: #5DCAA5; -fx-font-size: 10px;" text="●" />
                    <Label style="-fx-text-fill: #C0DDC0; -fx-font-size: 13px;" text="Redeem rewards from the catalog" />
                </HBox>
                <HBox spacing="12" style="-fx-alignment: center-left;">
                    <Label style="-fx-text-fill: #5DCAA5; -fx-font-size: 10px;" text="●" />
                    <Label style="-fx-text-fill: #C0DDC0; -fx-font-size: 13px;" text="Track your campus leaderboard rank" />
                </HBox>
            </VBox>
        </VBox>

        <!-- Right login form panel -->
        <VBox prefHeight="600" prefWidth="480" spacing="0" style="-fx-background-color: white; -fx-alignment: center; -fx-padding: 60 56 60 56;">

            <Label style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #1A3A2A;" text="Welcome back" />
            <Label style="-fx-font-size: 13px; -fx-text-fill: #6B8C7A; -fx-padding: 6 0 32 0;" text="Sign in to your account" />

            <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #3A5A4A;" text="Student ID" />
            <TextField fx:id="studentIdTextField" prefHeight="42" promptText="e.g. 2024-00123" style="-fx-background-color: #F5F9F5; -fx-border-color: #C0D8C8; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 10 14; -fx-font-size: 14px;">
                <VBox.margin><Insets bottom="20" top="6" /></VBox.margin>
            </TextField>

            <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #3A5A4A;" text="Password" />
            <PasswordField fx:id="passwordTextField" prefHeight="42" promptText="Enter your password" style="-fx-background-color: #F5F9F5; -fx-border-color: #C0D8C8; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 10 14; -fx-font-size: 14px;">
                <VBox.margin><Insets bottom="8" top="6" /></VBox.margin>
            </PasswordField>

            <HBox style="-fx-alignment: center-right;">
                <Hyperlink fx:id="forgotPasswordHyperlink" style="-fx-text-fill: #1D9E75; -fx-font-size: 12px; -fx-border-color: transparent;" text="Forgot password?" />
                <VBox.margin><Insets bottom="24" /></VBox.margin>
            </HBox>

            <Label fx:id="errorLabel" style="-fx-text-fill: #C0392B; -fx-font-size: 12px;" text="">
                <VBox.margin><Insets bottom="8" /></VBox.margin>
            </Label>

            <Button fx:id="signInButton" onAction="#onSignInButtonClicked" prefHeight="44" prefWidth="368" style="-fx-background-color: #1D9E75; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-border-radius: 8; -fx-background-radius: 8; -fx-cursor: hand;" text="Sign In" />

            <HBox spacing="4" style="-fx-alignment: center; -fx-padding: 24 0 0 0;">
                <Label style="-fx-font-size: 13px; -fx-text-fill: #6B8C7A;" text="Don't have an account?" />
                <Hyperlink fx:id="registerHyperlink" onAction="#onRegisterHyperlinkClicked" style="-fx-text-fill: #1D9E75; -fx-font-size: 13px; -fx-font-weight: bold; -fx-border-color: transparent;" text="Register here" />
            </HBox>

            <!-- Admin link -->
            <HBox spacing="4" style="-fx-alignment: center; -fx-padding: 12 0 0 0;">
                <Hyperlink fx:id="adminLoginHyperlink" onAction="#onAdminLoginHyperlinkClicked" style="-fx-text-fill: #A0B8A8; -fx-font-size: 12px; -fx-border-color: transparent;" text="Admin Login →" />
            </HBox>
        </VBox>
    </HBox>
</StackPane>
