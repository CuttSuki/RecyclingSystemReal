<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.Region?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      style="-fx-padding: 32 36;" spacing="24">

    <!-- Header -->
    <HBox style="-fx-alignment: center-left;">
        <VBox HBox.hgrow="ALWAYS" spacing="2">
            <Label text="🏆 Leaderboard" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1A3A2A;"/>
            <Label text="Top recyclers on campus this semester" style="-fx-font-size: 13px; -fx-text-fill: #6B8C7A;"/>
        </VBox>
        <Label fx:id="yourRankBadge" text="Your Rank: #3"
               style="-fx-background-color: #1D9E75; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 20; -fx-padding: 8 20;"/>
    </HBox>

    <!-- Top 3 podium -->
    <HBox spacing="16" style="-fx-alignment: bottom-center; -fx-padding: 0 0 8 0;">

        <!-- 2nd place -->
        <VBox prefWidth="200" spacing="8"
              style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #D8EBE0; -fx-border-radius: 12; -fx-padding: 20; -fx-alignment: center;">
            <Label text="🥈" style="-fx-font-size: 28px;"/>
            <VBox style="-fx-background-color: #C8C8C8; -fx-background-radius: 20; -fx-min-width: 44; -fx-min-height: 44; -fx-alignment: center;">
                <Label text="MR" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            </VBox>
            <Label text="Maria Reyes" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1A3A2A;"/>
            <Label text="BSCS - 3" style="-fx-font-size: 11px; -fx-text-fill: #6B8C7A;"/>
            <Label text="210 bottles" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1D9E75;"/>
            <Label text="105.0 pts" style="-fx-font-size: 12px; -fx-text-fill: #6B8C7A;"/>
        </VBox>

        <!-- 1st place - taller / highlighted -->
        <VBox prefWidth="220" spacing="8"
              style="-fx-background-color: #1A3A2A; -fx-background-radius: 12; -fx-border-radius: 12; -fx-padding: 24; -fx-alignment: center;">
            <Label text="🥇" style="-fx-font-size: 32px;"/>
            <VBox style="-fx-background-color: #1D9E75; -fx-background-radius: 24; -fx-min-width: 48; -fx-min-height: 48; -fx-alignment: center;">
                <Label text="CA" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            </VBox>
            <Label text="Carlo Aquino" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Label text="BSIT - 4" style="-fx-font-size: 11px; -fx-text-fill: #9FE1CB;"/>
            <Label text="356 bottles" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #5DCAA5;"/>
            <Label text="178.0 pts" style="-fx-font-size: 12px; -fx-text-fill: #9FE1CB;"/>
        </VBox>

        <!-- 3rd place (highlighted - it's YOU) -->
        <VBox prefWidth="200" spacing="8"
              style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #1D9E75; -fx-border-width: 2; -fx-border-radius: 12; -fx-padding: 20; -fx-alignment: center;">
            <Label text="🥉" style="-fx-font-size: 28px;"/>
            <VBox style="-fx-background-color: #1D9E75; -fx-background-radius: 20; -fx-min-width: 44; -fx-min-height: 44; -fx-alignment: center;">
                <Label text="JD" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            </VBox>
            <HBox spacing="4" style="-fx-alignment: center;">
                <Label text="Juan Dela Cruz" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1A3A2A;"/>
            </HBox>
            <Label text="BSCS - 2  (You)" style="-fx-font-size: 11px; -fx-text-fill: #1D9E75; -fx-font-weight: bold;"/>
            <Label text="142 bottles" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1D9E75;"/>
            <Label text="71.0 pts" style="-fx-font-size: 12px; -fx-text-fill: #6B8C7A;"/>
        </VBox>
    </HBox>

    <!-- Full Rankings Table -->
    <VBox VBox.vgrow="ALWAYS"
          style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #D8EBE0; -fx-border-radius: 12; -fx-padding: 20;"
          spacing="12">
        <Label text="Full Rankings" style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1A3A2A;"/>
        <TableView fx:id="leaderboardTable" VBox.vgrow="ALWAYS"
                   style="-fx-background-color: transparent; -fx-border-color: transparent;">
            <columns>
                <TableColumn fx:id="rankCol" text="Rank" prefWidth="70"/>
                <TableColumn fx:id="nameCol" text="Student Name" prefWidth="200"/>
                <TableColumn fx:id="deptCol" text="Department" prefWidth="150"/>
                <TableColumn fx:id="bottlesLbCol" text="Bottles" prefWidth="100"/>
                <TableColumn fx:id="pointsLbCol" text="Points" prefWidth="100"/>
                <TableColumn fx:id="badgeCol" text="Badge" prefWidth="120"/>
            </columns>
        </TableView>
    </VBox>
</VBox>
