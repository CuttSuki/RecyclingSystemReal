<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane prefHeight="640" prefWidth="900" style="-fx-background-color: #F0F4F0;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.recyclingsystemreal.RegisterController">

    <HBox>
        <!-- Left panel -->
        <VBox prefHeight="640" prefWidth="340" style="-fx-background-color: #0F6E56; -fx-alignment: center; -fx-padding: 60 40;">
            <Label style="-fx-font-size: 56px; -fx-text-fill: #9FE1CB;" text="♻" />
            <Label style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: white; -fx-padding: 12 0 8 0; -fx-wrap-text: true; -fx-alignment: center;" text="Join EcoRewards" />
            <Label style="-fx-font-size: 13px; -fx-text-fill: #9FE1CB; -fx-wrap-text: true; -fx-alignment: center; -fx-text-alignment: center;" text="Create your account and start earning points for every bottle you recycle." />

            <VBox spacing="20" style="-fx-padding: 40 0 0 0; -fx-alignment: center;">
                <VBox spacing="4" style="-fx-background-color: #085041; -fx-background-radius: 12; -fx-padding: 16; -fx-alignment: center;">
                    <Label style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #5DCAA5;" text="1 pt" />
                    <Label style="-fx-font-size: 12px; -fx-text-fill: #9FE1CB;" text="per bottle" />
                </VBox>
                <VBox spacing="4" style="-fx-background-color: #085041; -fx-background-radius: 12; -fx-padding: 16; -fx-alignment: center;">
                    <Label style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #5DCAA5;" text="10 pts" />
                    <Label style="-fx-font-size: 12px; -fx-text-fill: #9FE1CB;" text="= 1 Ballpen reward" />
                </VBox>
            </VBox>
        </VBox>

        <!-- Right registration form -->
        <VBox prefHeight="640" prefWidth="560" spacing="0" style="-fx-background-color: white; -fx-alignment: center; -fx-padding: 50 56;">

            <Label style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1A3A2A;" text="Create Account" />
            <Label style="-fx-font-size: 13px; -fx-text-fill: #6B8C7A; -fx-padding: 6 0 28 0;" text="Fill in your details to get started" />

            <!-- Full Name -->
            <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #3A5A4A;" text="Full Name" />
            <TextField fx:id="fullNameField" prefHeight="42" promptText="Juan dela Cruz" style="-fx-background-color: #F5F9F5; -fx-border-color: #C0D8C8; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 10 14; -fx-font-size: 14px;">
                <VBox.margin><Insets bottom="16" top="6" /></VBox.margin>
            </TextField>

            <!-- Student ID -->
            <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #3A5A4A;" text="Student ID" />
            <TextField fx:id="studentIdField" prefHeight="42" promptText="2024-00123" style="-fx-background-color: #F5F9F5; -fx-border-color: #C0D8C8; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 10 14; -fx-font-size: 14px;">
                <VBox.margin><Insets bottom="16" top="6" /></VBox.margin>
            </TextField>

            <!-- Department & Year in one row -->
            <HBox spacing="12">
                <VBox spacing="0" HBox.hgrow="ALWAYS">
                    <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #3A5A4A;" text="Department" />
                    <ComboBox fx:id="departmentCombo" prefHeight="42" prefWidth="232" promptText="Select dept." style="-fx-background-color: #F5F9F5; -fx-border-color: #C0D8C8; -fx-border-radius: 8; -fx-background-radius: 8;">
                        <VBox.margin><Insets top="6" /></VBox.margin>
                    </ComboBox>
                </VBox>
                <VBox spacing="0" HBox.hgrow="ALWAYS">
                    <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #3A5A4A;" text="Year Level" />
                    <ComboBox fx:id="yearCombo" prefHeight="42" prefWidth="232" promptText="Select year" style="-fx-background-color: #F5F9F5; -fx-border-color: #C0D8C8; -fx-border-radius: 8; -fx-background-radius: 8;">
                        <VBox.margin><Insets top="6" /></VBox.margin>
                    </ComboBox>
                </VBox>
                <VBox.margin><Insets bottom="16" /></VBox.margin>
            </HBox>

            <!-- Password -->
            <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #3A5A4A;" text="Password" />
            <PasswordField fx:id="passwordField" prefHeight="42" promptText="Create a password" style="-fx-background-color: #F5F9F5; -fx-border-color: #C0D8C8; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 10 14; -fx-font-size: 14px;">
                <VBox.margin><Insets bottom="16" top="6" /></VBox.margin>
            </PasswordField>

            <!-- Confirm Password -->
            <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #3A5A4A;" text="Confirm Password" />
            <PasswordField fx:id="confirmPasswordField" prefHeight="42" promptText="Repeat password" style="-fx-background-color: #F5F9F5; -fx-border-color: #C0D8C8; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 10 14; -fx-font-size: 14px;">
                <VBox.margin><Insets bottom="8" top="6" /></VBox.margin>
            </PasswordField>

            <Label fx:id="errorLabel" style="-fx-text-fill: #C0392B; -fx-font-size: 12px;" text="">
                <VBox.margin><Insets bottom="8" /></VBox.margin>
            </Label>

            <Button fx:id="registerButton" prefHeight="44" prefWidth="448" style="-fx-background-color: #1D9E75; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-border-radius: 8; -fx-background-radius: 8; -fx-cursor: hand;" text="Create Account" />

            <HBox spacing="4" style="-fx-alignment: center; -fx-padding: 16 0 0 0;">
                <Label style="-fx-font-size: 13px; -fx-text-fill: #6B8C7A;" text="Already have an account?" />
                <Hyperlink style="-fx-text-fill: #1D9E75; -fx-font-size: 13px; -fx-font-weight: bold; -fx-border-color: transparent;" text="Sign in" />
            </HBox>
        </VBox>
    </HBox>
</StackPane>
